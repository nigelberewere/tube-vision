# Janso Studio - Local Development Environment Configuration
# For PRODUCTION configuration, see .env.production.example

# APP_URL: The URL where this applet is hosted.
# For local development, this should be your localhost URL
APP_URL="http://localhost:3000"

# ============================================================================
# Supabase Configuration (Required for production)
# ============================================================================
# Get these from: https://app.supabase.com/project/_/settings/api
#
# FRONTEND (.env.local - Vite environment variables):
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-public-key-here"
#
# BACKEND (server.ts - Node.js environment variables):
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key-here"
#
# WARNING: Never commit SUPABASE_SERVICE_ROLE_KEY to version control!
# The service role key bypasses Row Level Security - keep it secret!
# ============================================================================

# Google OAuth Credentials (Required)
# Obtain these from the Google Cloud Console (https://console.cloud.google.com/apis/credentials)
# For local development, set redirect URI to: http://localhost:3000/auth/google/callback
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"
SESSION_SECRET="A_RANDOM_LONG_STRING_FOR_SESSIONS"

# Note: GEMINI_API_KEY is no longer configured here
# Users provide their own Gemini API keys through Settings → API Keys in the app
# Get your free key from: https://aistudio.google.com/app/apikey
# This enables better privacy, scalability, and per-user quota management

# ============================================================================
# Development Settings (Optional)
# ============================================================================
NODE_ENV="development"

# For production deployment to Cloudflare Pages:
# 1. Copy .env.production.example to .env.production
# 2. Set all production values
# 3. Configure in Cloudflare Dashboard > Environment Variables
# 4. See cloudflare-pages.md for complete deployment guide

