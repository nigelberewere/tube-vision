{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/favicon.ico",
      "destination": "https://app.janso.studio/favicon.svg",
      "permanent": true
    },
    {
      "source": "/favicon.svg",
      "destination": "https://app.janso.studio/favicon.svg",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/((?!.*\\.).*)",
      "destination": "/"
    }
  ]
}
