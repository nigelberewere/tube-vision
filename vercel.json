{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/route.ts": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/route?path=api/$1"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/route?path=auth/$1"
    }
  ]
}
